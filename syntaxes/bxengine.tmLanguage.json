{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "bxengine",
  "scopeName": "source.bxengine",
  "patterns": [
    {
      "include": "#commentFunction"
    },
    {
      "include": "#string"
    },
    {
      "name": "entity.name.function.bxengine",
      "match": "(?<=\\[)\\s*(?!\\/\\/)[@A-Za-z_#][A-Za-z0-9_@#\\/]*"
    },
    {
      "name": "constant.numeric.bxengine",
      "match": "(?<![A-Za-z0-9_])[-+]?(?:\\d+(?:\\.\\d*)?|\\.\\d+)(?![A-Za-z0-9_])"
    }
  ],
  "repository": {
    "string": {
      "name": "string.quoted.double.bxengine",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.bxengine",
          "match": "\\\\."
        }
      ]
    },
    "commentFunction": {
      "begin": "\\[\\s*//(?=\\s|\\]|$)",
      "beginCaptures": {
        "0": {
          "name": "comment.block.bxengine punctuation.definition.comment.begin.bxengine"
        }
      },
      "end": "\\]",
      "endCaptures": {
        "0": {
          "name": "comment.block.bxengine punctuation.definition.comment.end.bxengine"
        }
      },
      "name": "comment.block.bxengine",
      "patterns": [
        {
          "include": "#string"
        },
        {
          "include": "#nestedBracketCommentBody"
        }
      ]
    },
    "nestedBracketCommentBody": {
      "begin": "\\[",
      "beginCaptures": {
        "0": {
          "name": "comment.block.bxengine punctuation.definition.comment.begin.bxengine"
        }
      },
      "end": "\\]",
      "endCaptures": {
        "0": {
          "name": "comment.block.bxengine punctuation.definition.comment.end.bxengine"
        }
      },
      "name": "comment.block.bxengine",
      "patterns": [
        {
          "include": "#string"
        },
        {
          "include": "#nestedBracketCommentBody"
        }
      ]
    }
  }
}
